<UserControl x:Class="Schedule1ModdingTool.Views.GlobalStatePropertiesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:Schedule1ModdingTool.Models"
             xmlns:views="clr-namespace:Schedule1ModdingTool.Views"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1000">

    <Grid Margin="8">
        <TabControl Style="{StaticResource EditorTabControlStyle}" VerticalAlignment="Stretch">
            <TabItem Header="Overview">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <WrapPanel Margin="12" DataContext="{Binding SelectedGlobalState}">
                        <Border Style="{StaticResource PanelStyle}" Margin="0,0,12,12" MinWidth="340" MaxWidth="520">
                            <StackPanel Margin="12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Identity" Style="{StaticResource PanelHeaderStyle}" Margin="0,0,8,0" />
                                    <views:InfoIcon TooltipText="Global Save Variables generate S1API Saveable subclasses. Keep Class Name stable once people start using the mod, because rename changes the generated type and can break saved-state expectations." />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Label Content="State Name" Style="{StaticResource LabelStyle}" />
                                    <views:InfoIcon TooltipText="Player-facing/editor-facing label for this saveable. This is the friendly name shown in the workspace." />
                                </StackPanel>
                                <TextBox Text="{Binding StateName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" />

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Label Content="Class Name" Style="{StaticResource LabelStyle}" />
                                    <views:InfoIcon PropertyName="ClassName" />
                                </StackPanel>
                                <TextBox Text="{Binding ClassName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" />

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Label Content="Namespace" Style="{StaticResource LabelStyle}" />
                                    <views:InfoIcon TooltipText="Namespace for the generated Saveable class. The default .Saveables suffix keeps generated state classes grouped cleanly in the exported mod." />
                                </StackPanel>
                                <TextBox Text="{Binding Namespace, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelStyle}" Margin="0,0,12,12" MinWidth="320" MaxWidth="440">
                            <StackPanel Margin="12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Persistence" Style="{StaticResource PanelHeaderStyle}" Margin="0,0,8,0" />
                                    <views:InfoIcon TooltipText="Use Load Order to control when this Saveable loads relative to base-game saveables. Hook Scaffold generates a partial file so advanced users can react to save/load without editing generated code." />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Label Content="Load Order" Style="{StaticResource LabelStyle}" />
                                    <views:InfoIcon PropertyName="LoadOrder" />
                                </StackPanel>
                                <ComboBox ItemsSource="{x:Static models:GlobalStateBlueprintOptions.LoadOrders}"
                                          SelectedItem="{Binding LoadOrder, UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource ComboBoxStyle}" />

                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <CheckBox Content="Generate Hook Scaffold"
                                              IsChecked="{Binding GenerateHookScaffold, UpdateSourceTrigger=PropertyChanged}"
                                              Foreground="{StaticResource LightTextBrush}" />
                                    <views:InfoIcon PropertyName="GenerateHookScaffold" />
                                </StackPanel>

                                <TextBlock Margin="0,12,0,0"
                                           Foreground="{StaticResource DimTextBrush}"
                                           TextWrapping="Wrap"
                                           Text="Generated saveables auto-register through S1API discovery. You do not need to call a manual registration method from Core." />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelStyle}" Margin="0,0,12,12" MinWidth="340" MaxWidth="520">
                            <StackPanel Margin="12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Metadata" Style="{StaticResource PanelHeaderStyle}" Margin="0,0,8,0" />
                                    <views:InfoIcon TooltipText="These fields are copied into the generated file metadata flow so exported saveables stay aligned with the rest of the mod project." />
                                </StackPanel>

                                <Label Content="Mod Name" Style="{StaticResource LabelStyle}" Margin="0,12,0,0" />
                                <TextBox Text="{Binding ModName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" />

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <Label Content="Version" Style="{StaticResource LabelStyle}" />
                                        <TextBox Text="{Binding ModVersion, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <Label Content="Author" Style="{StaticResource LabelStyle}" />
                                        <TextBox Text="{Binding ModAuthor, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" />
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <Label Content="Game Developer" Style="{StaticResource LabelStyle}" />
                                        <TextBox Text="{Binding GameDeveloper, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <Label Content="Game Name" Style="{StaticResource LabelStyle}" />
                                        <TextBox Text="{Binding GameName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Fields">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="12">
                        <DockPanel Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                <TextBlock Text="Saved Fields" Style="{StaticResource PanelHeaderStyle}" Margin="0,0,8,0" />
                                <views:InfoIcon TooltipText="Each field becomes one [SaveableField] entry on the generated Saveable class. Save Key is the serialized key written into the save file. Keep Save Key stable once the mod ships so old saves still load." />
                            </StackPanel>
                            <Button Content="+ Add Field"
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource IconButtonStyle}"
                                    Click="AddField_Click" />
                        </DockPanel>

                        <TextBlock Foreground="{StaticResource DimTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"
                                   Text="Use stable Save Keys for released mods. Renaming a field is safe if the Save Key stays the same; changing the Save Key changes the serialized slot in player saves." />

                        <ItemsControl ItemsSource="{Binding SelectedGlobalState.Fields}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:GlobalStateFieldBlueprint}">
                                    <Border Style="{StaticResource PanelStyle}" Margin="0,0,0,12">
                                        <StackPanel Margin="12">
                                            <DockPanel Margin="0,0,0,8">
                                                <TextBlock Text="{Binding FieldName, TargetNullValue=New Field, FallbackValue=New Field}"
                                                           Style="{StaticResource PanelHeaderStyle}"
                                                           DockPanel.Dock="Left" />
                                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                                    <Button Content="Duplicate"
                                                            Style="{StaticResource IconButtonStyle}"
                                                            Margin="0,0,8,0"
                                                            Tag="{Binding}"
                                                            Click="DuplicateField_Click" />
                                                    <Button Content="Remove"
                                                            Style="{StaticResource IconButtonStyle}"
                                                            Tag="{Binding}"
                                                            Click="RemoveField_Click" />
                                                </StackPanel>
                                            </DockPanel>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Label Content="Field Name" Style="{StaticResource LabelStyle}" />
                                                        <views:InfoIcon PropertyName="FieldName"
                                                                        ExperienceLevel="{Binding DataContext.Settings.ExperienceLevel, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                    </StackPanel>
                                                    <TextBox Text="{Binding FieldName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Label Content="Save Key (optional)" Style="{StaticResource LabelStyle}" />
                                                        <views:InfoIcon TooltipText="Serialized key stored in the save file. Leave blank to reuse Field Name. Keep this stable after release so existing saves continue loading into the same field." />
                                                    </StackPanel>
                                                    <TextBox Text="{Binding SaveKey, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" />
                                                </StackPanel>
                                            </Grid>

                                            <Grid Margin="0,8,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="220" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Label Content="Field Type" Style="{StaticResource LabelStyle}" />
                                                        <views:InfoIcon PropertyName="FieldType"
                                                                        ExperienceLevel="{Binding DataContext.Settings.ExperienceLevel, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                    </StackPanel>
                                                    <ComboBox ItemsSource="{x:Static models:GlobalStateBlueprintOptions.FieldTypes}"
                                                              SelectedItem="{Binding FieldType, UpdateSourceTrigger=PropertyChanged}"
                                                              Style="{StaticResource ComboBoxStyle}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Label Content="Default Value (optional)" Style="{StaticResource LabelStyle}" />
                                                        <views:InfoIcon PropertyName="DefaultValue"
                                                                        ExperienceLevel="{Binding DataContext.Settings.ExperienceLevel, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                                    </StackPanel>
                                                    <TextBox Text="{Binding DefaultValue, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource TextBoxStyle}"
                                                             Height="70"
                                                             AcceptsReturn="True"
                                                             TextWrapping="Wrap"
                                                             VerticalScrollBarVisibility="Auto">
                                                        <TextBox.ToolTip>
                                                            <TextBlock Text="For ListString values, enter one item per line or separate items with commas. For other types, use normal literals like true, 5, 1.5, or Hello." TextWrapping="Wrap" MaxWidth="320" />
                                                        </TextBox.ToolTip>
                                                    </TextBox>
                                                </StackPanel>
                                            </Grid>

                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                <Label Content="Comment (optional)" Style="{StaticResource LabelStyle}" />
                                                <views:InfoIcon PropertyName="Comment"
                                                                ExperienceLevel="{Binding DataContext.Settings.ExperienceLevel, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                            </StackPanel>
                                            <TextBox Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource TextBoxStyle}"
                                                     Height="60"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     VerticalScrollBarVisibility="Auto" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
