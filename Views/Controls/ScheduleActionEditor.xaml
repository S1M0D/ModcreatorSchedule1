<UserControl x:Class="Schedule1ModdingTool.Views.Controls.ScheduleActionEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:models="clr-namespace:Schedule1ModdingTool.Models"
             xmlns:controls="clr-namespace:Schedule1ModdingTool.Views.Controls"
             xmlns:views="clr-namespace:Schedule1ModdingTool.Views"
             xmlns:utils="clr-namespace:Schedule1ModdingTool.Utils"
             mc:Ignorable="d"
             d:DesignHeight="520" d:DesignWidth="520">
    <UserControl.Resources>
        <utils:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Border Style="{StaticResource PanelStyle}" Padding="12">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="Action Details" Style="{StaticResource PanelHeaderStyle}"/>
                <views:InfoIcon TooltipText="Schedule actions map to S1API schedule builders. Pick an action type first, then fill the extra fields that appear below."/>
            </StackPanel>
            <TextBlock Text="Only the fields for the selected action type matter. Leave optional fields blank when you want S1API to use its default lookup behavior."
                       Foreground="{StaticResource DimTextBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"/>

            <Label Content="Action Type" Style="{StaticResource LabelStyle}"/>
            <ComboBox x:Name="ActionTypeComboBox"
                      ItemsSource="{Binding Source={x:Type models:ScheduleActionType}, Converter={StaticResource EnumToCollectionConverter}}"
                      SelectedItem="{Binding ActionType}"
                      SelectionChanged="ActionTypeComboBox_SelectionChanged"
                      Style="{StaticResource ComboBoxStyle}"
                      Margin="0,0,0,8"/>

            <controls:TimeInput Time="{Binding StartTime, Mode=TwoWay}" Label="Start Time" Margin="0,0,0,8"/>

            <Label Content="Custom Action Name (Optional)" Style="{StaticResource LabelStyle}"/>
            <TextBox Text="{Binding ActionName, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource TextBoxStyle}"
                     Margin="0,0,0,12"/>

            <StackPanel x:Name="DynamicFieldsPanel">
                <StackPanel x:Name="WalkToFields" Visibility="Collapsed">
                    <Label Content="Walk To Position" Style="{StaticResource LabelStyle}"/>
                    <controls:Vector3Input X="{Binding PositionX, Mode=TwoWay}" Y="{Binding PositionY, Mode=TwoWay}" Z="{Binding PositionZ, Mode=TwoWay}" Margin="0,0,0,8"/>
                    <CheckBox Content="Face Destination Direction" IsChecked="{Binding FaceDestinationDirection}" Foreground="{StaticResource LightTextBrush}" Margin="0,0,0,8"/>
                    <Label Content="Within Distance" Style="{StaticResource LabelStyle}"/>
                    <TextBox Text="{Binding Within, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,8"/>
                    <CheckBox Content="Warp If Skipped" IsChecked="{Binding WarpIfSkipped}" Foreground="{StaticResource LightTextBrush}" Margin="0,0,0,8"/>
                    <CheckBox Content="Use Custom Forward Direction" IsChecked="{Binding HasForward}" Foreground="{StaticResource LightTextBrush}" Margin="0,0,0,8"/>
                    <StackPanel Visibility="{Binding HasForward, Converter={StaticResource BoolToVisibilityConverter}}" Margin="20,0,0,12">
                        <Label Content="Forward Direction Vector" Style="{StaticResource LabelStyle}"/>
                        <controls:Vector3Input X="{Binding ForwardX, Mode=TwoWay}" Y="{Binding ForwardY, Mode=TwoWay}" Z="{Binding ForwardZ, Mode=TwoWay}" Margin="0,0,0,12"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel x:Name="StayInBuildingFields" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Building" Style="{StaticResource LabelStyle}"/>
                        <views:InfoIcon TooltipText="Select a building identifier type from S1API.Map.Buildings."/>
                    </StackPanel>
                    <views:BuildingSelector x:Name="BuildingSelector" SelectedBuildingTypeName="{Binding BuildingName, Mode=TwoWay}" Margin="0,0,0,8"/>
                    <Label Content="Duration (minutes)" Style="{StaticResource LabelStyle}"/>
                    <TextBox Text="{Binding Duration, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,8"/>
                    <Label Content="Door Index (Optional)" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="DoorIndexTextBox" Text="{Binding DoorIndex, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,12" LostFocus="DoorIndexTextBox_LostFocus"/>
                </StackPanel>

                <StackPanel x:Name="LocationDialogueFields" Visibility="Collapsed">
                    <Label Content="Dialogue Position" Style="{StaticResource LabelStyle}"/>
                    <controls:Vector3Input X="{Binding PositionX, Mode=TwoWay}" Y="{Binding PositionY, Mode=TwoWay}" Z="{Binding PositionZ, Mode=TwoWay}" Margin="0,0,0,8"/>
                    <CheckBox Content="Face Destination Direction" IsChecked="{Binding FaceDestinationDirection}" Foreground="{StaticResource LightTextBrush}" Margin="0,0,0,8"/>
                    <Label Content="Within Distance" Style="{StaticResource LabelStyle}"/>
                    <TextBox Text="{Binding Within, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,8"/>
                    <CheckBox Content="Warp If Skipped" IsChecked="{Binding WarpIfSkipped}" Foreground="{StaticResource LightTextBrush}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Greeting Override Index" Style="{StaticResource LabelStyle}"/>
                        <views:InfoIcon TooltipText="Advanced override index used by the base-game location dialogue system. Leave at the default unless you know the exact greeting slot you want to enable."/>
                    </StackPanel>
                    <TextBox Text="{Binding GreetingOverrideToEnable, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Choice Index" Style="{StaticResource LabelStyle}"/>
                        <views:InfoIcon TooltipText="Advanced base-game dialogue choice index. Leave at the default unless you are intentionally enabling a known existing choice slot."/>
                    </StackPanel>
                    <TextBox Text="{Binding ChoiceToEnable, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,12"/>
                </StackPanel>

                <StackPanel x:Name="LocationBasedFields" Visibility="Collapsed">
                    <TextBlock Text="Location based actions can trigger smoke breaks, graffiti, drinking, or held-item behavior when the NPC reaches the destination."
                               Foreground="{StaticResource DimTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"/>
                    <Label Content="Destination Position" Style="{StaticResource LabelStyle}"/>
                    <controls:Vector3Input X="{Binding PositionX, Mode=TwoWay}" Y="{Binding PositionY, Mode=TwoWay}" Z="{Binding PositionZ, Mode=TwoWay}" Margin="0,0,0,8"/>
                    <Label Content="Duration (minutes)" Style="{StaticResource LabelStyle}"/>
                    <TextBox Text="{Binding Duration, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,8"/>
                    <CheckBox Content="Face Destination Direction" IsChecked="{Binding FaceDestinationDirection}" Foreground="{StaticResource LightTextBrush}" Margin="0,0,0,8"/>
                    <CheckBox Content="Warp If Skipped" IsChecked="{Binding WarpIfSkipped}" Foreground="{StaticResource LightTextBrush}" Margin="0,0,0,8"/>
                    <Label Content="Within Distance" Style="{StaticResource LabelStyle}"/>
                    <TextBox Text="{Binding Within, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Arrive Behavior" Style="{StaticResource LabelStyle}"/>
                        <views:InfoIcon TooltipText="What the NPC should do on arrival. SmokeBreak uses the prefab smoke-break setup, Graffiti uses spray paint, Drinking uses a drink equippable, and HoldItem uses a generic AvatarEquippable."/>
                    </StackPanel>
                    <ComboBox ItemsSource="{Binding Source={x:Type models:LocationArriveBehaviourOption}, Converter={StaticResource EnumToCollectionConverter}}"
                              SelectedItem="{Binding LocationArriveBehaviour}"
                              Style="{StaticResource ComboBoxStyle}"
                              Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Held Item Equippable Path" Style="{StaticResource LabelStyle}"/>
                        <views:InfoIcon TooltipText="Used by HoldItem. Example: 'Avatar/Equippables/Phone_Lowered' or 'Tools/Flashlight/Flashlight_AvatarEquippable'."/>
                    </StackPanel>
                    <TextBox Text="{Binding ItemEquippablePath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Drink Equippable Path" Style="{StaticResource LabelStyle}"/>
                        <views:InfoIcon TooltipText="Used by Drinking. Example: 'Avatar/Equippables/Beer' or 'Avatar/Equippables/Coffee'."/>
                    </StackPanel>
                    <TextBox Text="{Binding DrinkEquippablePath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Graffiti Region" Style="{StaticResource LabelStyle}"/>
                        <views:InfoIcon TooltipText="Used by Graffiti when you want S1API to search for a spray surface inside a region instead of targeting a specific surface GUID."/>
                    </StackPanel>
                    <ComboBox Text="{Binding GraffitiRegion, UpdateSourceTrigger=PropertyChanged}" IsEditable="True" Style="{StaticResource ComboBoxStyle}" Margin="0,0,0,8">
                        <ComboBoxItem Content="Northtown"/>
                        <ComboBoxItem Content="Westville"/>
                        <ComboBoxItem Content="Downtown"/>
                        <ComboBoxItem Content="Docks"/>
                        <ComboBoxItem Content="Suburbia"/>
                        <ComboBoxItem Content="Uptown"/>
                    </ComboBox>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Graffiti Surface GUID (Optional)" Style="{StaticResource LabelStyle}"/>
                        <views:InfoIcon TooltipText="Exact spray surface GUID to tag. Use this when you want a specific wall or surface. Leave blank to let the region lookup decide."/>
                    </StackPanel>
                    <TextBox Text="{Binding GraffitiSurfaceGuid, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,12"/>
                </StackPanel>

                <StackPanel x:Name="DriveToCarParkFields" Visibility="Collapsed">
                    <Label Content="Parking Lot Name" Style="{StaticResource LabelStyle}"/>
                    <TextBox Text="{Binding ParkingLotName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,8"/>
                    <Label Content="Vehicle Code" Style="{StaticResource LabelStyle}"/>
                    <TextBox Text="{Binding VehicleId, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,8"/>
                    <Label Content="Vehicle Spawn Position" Style="{StaticResource LabelStyle}"/>
                    <controls:Vector3Input X="{Binding VehicleSpawnX, Mode=TwoWay}" Y="{Binding VehicleSpawnY, Mode=TwoWay}" Z="{Binding VehicleSpawnZ, Mode=TwoWay}" Margin="0,0,0,8"/>
                    <Label Content="Vehicle Rotation (Euler Angles)" Style="{StaticResource LabelStyle}"/>
                    <controls:Vector3Input X="{Binding VehicleRotationX, Mode=TwoWay}" Y="{Binding VehicleRotationY, Mode=TwoWay}" Z="{Binding VehicleRotationZ, Mode=TwoWay}" Margin="0,0,0,8"/>
                    <Label Content="Parking Alignment" Style="{StaticResource LabelStyle}"/>
                    <ComboBox SelectedItem="{Binding ParkingAlignment}" Style="{StaticResource ComboBoxStyle}" Margin="0,0,0,8">
                        <ComboBoxItem Content="FrontToKerb"/>
                        <ComboBoxItem Content="RearToKerb"/>
                        <ComboBoxItem Content="Parallel"/>
                    </ComboBox>
                    <Label Content="Override Parking Type (Optional)" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="OverrideParkingTypeComboBox" SelectionChanged="OverrideParkingTypeComboBox_SelectionChanged" Style="{StaticResource ComboBoxStyle}" Margin="0,0,0,12">
                        <ComboBoxItem Content="(Default)" Tag="{x:Null}"/>
                        <ComboBoxItem Content="True" Tag="True"/>
                        <ComboBoxItem Content="False" Tag="False"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel x:Name="SitAtSeatSetFields" Visibility="Collapsed">
                    <TextBlock Text="Seat actions target an AvatarSeatSet. Use the name for a quick lookup or the full hierarchy path when multiple seat sets share the same name."
                               Foreground="{StaticResource DimTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Seat Set Name" Style="{StaticResource LabelStyle}"/>
                        <views:InfoIcon TooltipText="GameObject name of the AvatarSeatSet. Example: 'Fast Food Booth'. S1API returns the first case-insensitive match."/>
                    </StackPanel>
                    <TextBox Text="{Binding SeatSetName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Seat Set Path (Optional)" Style="{StaticResource LabelStyle}"/>
                        <views:InfoIcon TooltipText="Full hierarchy path to the seat set. Example: 'Map/Hyland Point/Region_Docks/WaterFront/OutdoorBench (1)'. Use this when names are not unique."/>
                    </StackPanel>
                    <TextBox Text="{Binding SeatSetPath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,8"/>
                    <Label Content="Duration (minutes)" Style="{StaticResource LabelStyle}"/>
                    <TextBox Text="{Binding Duration, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,8"/>
                    <CheckBox Content="Warp If Skipped" IsChecked="{Binding WarpIfSkipped}" Foreground="{StaticResource LightTextBrush}" Margin="0,0,0,12"/>
                </StackPanel>

                <StackPanel x:Name="UseVendingMachineFields" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Machine GUID (Optional)" Style="{StaticResource LabelStyle}"/>
                        <views:InfoIcon TooltipText="Specific vending machine GUID. Leave blank to let S1API pick a suitable nearby machine automatically."/>
                    </StackPanel>
                    <TextBox Text="{Binding MachineGUID, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,12"/>
                </StackPanel>

                <StackPanel x:Name="UseATMFields" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <Label Content="ATM GUID (Optional)" Style="{StaticResource LabelStyle}"/>
                        <views:InfoIcon TooltipText="Specific ATM GUID. Leave blank to let S1API resolve a suitable ATM automatically."/>
                    </StackPanel>
                    <TextBox Text="{Binding ATMGUID, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,12"/>
                </StackPanel>

                <StackPanel x:Name="SlotMachineFields" Visibility="Collapsed">
                    <TextBlock Text="Slot machine actions search for the nearest machine to this position. Bet amount and session mode control how long the NPC keeps gambling."
                               Foreground="{StaticResource DimTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Slot Machine Position" Style="{StaticResource LabelStyle}"/>
                        <views:InfoIcon TooltipText="World position near the slot machine. The NPC searches around this point, so it does not need to be mathematically exact."/>
                    </StackPanel>
                    <controls:Vector3Input X="{Binding PositionX, Mode=TwoWay}" Y="{Binding PositionY, Mode=TwoWay}" Z="{Binding PositionZ, Mode=TwoWay}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Session Mode" Style="{StaticResource LabelStyle}"/>
                        <views:InfoIcon TooltipText="SingleSpin plays once. SpinCount uses the spin count field. UntilTime stops at End Time. UntilBroke plays until cash runs out. UntilTimeOrBroke stops on either condition."/>
                    </StackPanel>
                    <ComboBox ItemsSource="{Binding Source={x:Type models:NpcGamblingSessionMode}, Converter={StaticResource EnumToCollectionConverter}}"
                              SelectedItem="{Binding SlotMachineSessionMode}"
                              Style="{StaticResource ComboBoxStyle}"
                              Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Bet Amount" Style="{StaticResource LabelStyle}"/>
                        <views:InfoIcon TooltipText="Per-spin bet amount. Match real machine denominations where possible, for example 5, 10, 25, or 100."/>
                    </StackPanel>
                    <TextBox Text="{Binding SlotMachineBetAmount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Spin Count" Style="{StaticResource LabelStyle}"/>
                        <views:InfoIcon TooltipText="Only used by the SpinCount session mode. Set how many spins the NPC should attempt."/>
                    </StackPanel>
                    <TextBox Text="{Binding SlotMachineSpinCount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,8"/>
                    <controls:TimeInput Time="{Binding SlotMachineEndTime, Mode=TwoWay}" Label="End Time" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Time Between Spins (seconds)" Style="{StaticResource LabelStyle}"/>
                        <views:InfoIcon TooltipText="Delay between consecutive spins for multi-spin modes. Use a few seconds unless you want very fast gambling behavior."/>
                    </StackPanel>
                    <TextBox Text="{Binding SlotMachineTimeBetweenSpins, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Max Search Distance" Style="{StaticResource LabelStyle}"/>
                        <views:InfoIcon TooltipText="How far from the position S1API can search for a slot machine. Increase this if the NPC fails to find the intended machine."/>
                    </StackPanel>
                    <TextBox Text="{Binding SlotMachineMaxSearchDistance, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,12"/>
                </StackPanel>

                <StackPanel x:Name="NoExtraFields" Visibility="Collapsed">
                    <TextBlock Text="No additional configuration required for this action type."
                               Foreground="{StaticResource DimTextBrush}"
                               FontStyle="Italic"
                               Margin="0,8,0,12"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
